# ORVOX environment

# ---- Required for the admin panel & DB-backed site ----
# Neon (or any Postgres) connection string (pooled). Powers the public site
# data layer AND the admin control panel. Without it the public site falls back
# to typed seed data and the admin panel cannot authenticate.
# Get one at https://neon.tech → project → connection string (pooled).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&channel_binding=require"

# Random secret reserved for signed payloads. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET="change-me"

# ---- Optional ----
# Vercel Blob token — enables image uploads in the admin Media library.
# Auto-provisioned when you add a Blob store in the Vercel dashboard.
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Public base URL used for canonical links, sitemap, and OG metadata.
# NEXT_PUBLIC_SITE_URL="https://orvox.in"
