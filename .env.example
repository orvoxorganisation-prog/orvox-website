# ORVOX environment

# ---- Required for the admin panel & DB-backed site ----
# Neon (or any Postgres) connection string (pooled). Powers the public site
# data layer AND the admin control panel. Without it the public site falls back
# to typed seed data and the admin panel cannot authenticate.
# Get one at https://neon.tech → project → connection string (pooled).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&channel_binding=require"

# Secret used to HMAC-sign the participant session cookie. REQUIRED in
# production (the app refuses to issue sessions if left as "change-me").
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET="change-me"

# ---- Optional ----
# Vercel Blob token — enables image uploads in the admin Media library.
# Auto-provisioned when you add a Blob store in the Vercel dashboard.
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Public base URL used for canonical links, sitemap, and OG metadata.
# NEXT_PUBLIC_SITE_URL="https://orvox.in"

# ---- Email (transactional auth: verification + password reset) ----
# Without these, auth emails are logged server-side (with the link) instead of
# sent, so the flows stay testable in development.
# RESEND_API_KEY="re_..."
# EMAIL_FROM="no-reply@orvox.in"

# Require participants to verify their email before they can sign in. Keep
# unset/false until a mail provider is configured, or users can't get in.
# REQUIRE_EMAIL_VERIFICATION="false"

# ---- Admin hardening ----
# Comma-separated IP allowlist for the entire /admin area (office/VPN only).
# Leave unset to allow any IP. Example: "203.0.113.4,198.51.100.7"
# ADMIN_IP_ALLOWLIST=""

# ---- Scheduled cleanup (vercel.json cron -> /api/cron/cleanup) ----
# Shared secret the cron job must present; the route refuses to run without it.
# CRON_SECRET="change-me-too"
# Days to keep security audit logs before pruning. Default 365.
# AUDIT_RETENTION_DAYS="365"

# ---- Image optimizer allowlist ----
# Extra HTTPS hosts (besides Vercel Blob) the <Image> optimizer may fetch from.
# NEXT_PUBLIC_IMAGE_HOSTS="images.unsplash.com,cdn.example.com"
